{
  "version": "1.0",
  "servers": {
    "filesystem": {
      "description": "Datei-System Operationen für MineSearch Projekt",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "/app"],
      "transport": "stdio",
      "scope": "project",
      "timeout": 30000,
      "retries": 2,
      "errorHandling": "graceful"
    },
    "github": {
      "description": "GitHub Integration für Repository-Verwaltung",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "transport": "stdio",
      "scope": "project",
      "timeout": 30000,
      "retries": 2,
      "errorHandling": "graceful",
      "env": {
        "GITHUB_TOKEN": "${GITHUB_TOKEN}"
      }
    },
    "memory": {
      "description": "Persistenter Speicher für Projekt-Kontext",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-memory"],
      "transport": "stdio",
      "scope": "project",
      "timeout": 30000,
      "retries": 2,
      "errorHandling": "graceful"
    },
    "puppeteer": {
      "description": "Puppeteer Browser-Automatisierung für Tests und Scraping",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-puppeteer"],
      "transport": "stdio",
      "scope": "project",
      "timeout": 30000,
      "retries": 2,
      "errorHandling": "graceful"
    },
    "ref": {
      "description": "Ref.tools - Referenz und Code-Dokumentations-Tools",
      "url": "https://api.ref.tools/mcp?apiKey=ref-8f290247572d4a37c54c",
      "transport": "http",
      "scope": "project",
      "timeout": 30000,
      "retries": 3,
      "errorHandling": "graceful"
    }
  },
  "globalSettings": {
    "logLevel": "info",
    "errorHandling": "graceful",
    "fallbackMode": true,
    "healthCheckInterval": 60000,
    "enableHealthChecks": true,
    "healthCheckTimeout": 10000
  }
}