# API Keys
OPENROUTER_API_KEY=
PERPLEXITY_API_KEY=
CUSTOM_API_KEY=
CUSTOM_API_ENDPOINT=

# Database
DATABASE_PATH=./data/minesearch.db

# Logging
LOG_LEVEL=INFO
LOG_FILE_PATH=./logs/minesearch.log
LOG_MAX_SIZE_MB=10
LOG_BACKUP_COUNT=5

# Web Scraping
USER_AGENT=MineSearch/1.0
RESPECT_ROBOTS_TXT=true
SCRAPING_DELAY_SECONDS=1
REQUEST_TIMEOUT_SECONDS=30
RETRY_ATTEMPTS=3

# Export Settings
DEFAULT_EXPORT_PATH=./data/output/
DEFAULT_COLUMN_SEPARATOR=|
DEFAULT_CELL_SEPARATOR=+++
DEFAULT_ENCODING=utf-8

# Performance
MAX_CONCURRENT_REQUESTS=10

# Feature Flags
ENABLE_DEBUG_MODE=false
ENABLE_PERFORMANCE_MONITORING=true