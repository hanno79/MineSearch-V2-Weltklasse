# MineSearch v2 Environment Variables
# Kopiere diese Datei nach .env und fülle die API-Keys aus

# Perplexity API
PERPLEXITY_API_KEY=your_perplexity_api_key_here

# OpenRouter API
OPENROUTER_API_KEY=your_openrouter_api_key_here

# OpenAI API (für Premium-Modelle)
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic API (für Claude)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google API (für Gemini)
GEMINI_API_KEY=your_gemini_api_key_here

# Grok API
GROK_API_KEY=your_grok_api_key_here

# Abacus AI (optional)
ABACUSAI_API_KEY=your_abacus_api_key_here

# Tavily API (optional)
TAVILY_API_KEY=your_tavily_api_key_here

# Exa API (optional)
EXA_API_KEY=your_exa_api_key_here

# Firecrawl API (optional)
FIRECRAWL_API_KEY=your_firecrawl_api_key_here

# BrightData (optional)
BRIGHTDATA_USERNAME=your_brightdata_username
BRIGHTDATA_PASSWORD=your_brightdata_password

# ScrapingBee API (optional)
SCRAPINGBEE_API_KEY=your_scrapingbee_api_key_here

# Datenbank
DATABASE_URL=sqlite:///./mines.db

# Server-Konfiguration
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
LOG_LEVEL=INFO