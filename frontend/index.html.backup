    const resultsDiv = document.getElementById('results');
    
    if (data.success && data.data) {
        safeSetHTML(resultsDiv, `
            <div style="padding: 20px; background: #f0fdf4; border-radius: 8px; border: 1px solid #10b981;">
                <h3>✅ Suchergebnis für: ${sanitizeHTML(data.data.mine_name)}</h3>
                <div style="margin-top: 15px;">
                    <pre style="background: #f9f9f9; padding: 10px; border-radius: 4px; white-space: pre-wrap;">${sanitizeHTML(JSON.stringify(data.data, null, 2))}</pre>
                </div>
            </div>
        `);
    } else {
        safeSetHTML(resultsDiv, `
            <div style="padding: 20px; background: #fef2f2; border-radius: 8px;">
                <h3>❌ Fehler</h3>
                <p>${sanitizeHTML(data.error || 'Unbekannter Fehler')}</p>
