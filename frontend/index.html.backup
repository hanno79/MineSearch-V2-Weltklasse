/**
// ÄNDERUNG 10.08.2025: Tab-Generator-Funktionen (generateOverviewTab, generateScoresTab, generateFieldsTab, generatePerformanceTab) nach ui.js extrahiert


/**
 * ERWEITERTE FUNKTION: Zeigt detaillierte Modell-Informationen
 * Jetzt mit Konsistenz-Analysen und neuen Metriken
 */
window.showModelDetails = async function(modelId) {
    console.log(`📊 [MODEL-DETAILS] Loading comprehensive details for model: ${modelId}`);
    showNotification(`🔍 Lade umfassende Details für ${modelId}...`, 'info');
    
    try {
        // Neue erweiterte Details-API
        const response = await fetch(`${window.API_BASE_URL}/api/statistics/models/${encodeURIComponent(modelId)}/details?_cache_bust=${Date.now()}`);
        
        if (!response.ok) {
            throw new Error(`HTTP ${response.status}: ${response.statusText}`);
        }
        
        const data = await response.json();
        
        if (data && data.model_stats) {
            displayModelDetailsModal(modelId, data);
            showNotification(`✅ Details für ${modelId} geladen`, 'success');
        } else {
            throw new Error('Modell-Details nicht verfügbar');
        }
        
    } catch (error) {
        console.error(`❌ [MODEL-DETAILS] Error loading details for ${modelId}:`, error);
        showNotification(`❌ Fehler beim Laden der Details für ${modelId}`, 'error');
    }
};

/**
 * NEUE FUNKTION: Zeigt umfassendes Modell-Details-Modal
 * Mit Konsistenz-Analyse, Feld-Performance und erweiterten Metriken
 */
function displayModelDetailsModal(modelId, detailsData) {
    console.log(`🎯 [MODAL] Displaying comprehensive details for ${modelId}`);
    
    const modal = document.createElement('div');
    modal.className = 'model-details-modal';
    modal.style.cssText = `
        position: fixed; top: 0; left: 0; width: 100%; height: 100%; 
        background: rgba(0,0,0,0.8); z-index: 10000; display: flex; 
        align-items: center; justify-content: center; padding: 20px;
    `;
    
    const modalContent = document.createElement('div');
    modalContent.style.cssText = `
        background: white; border-radius: 12px; width: 90%; max-width: 1200px; 
        max-height: 90%; overflow-y: auto; box-shadow: 0 20px 60px rgba(0,0,0,0.3);
    `;
    
    const stats = detailsData.model_stats;
    const consistency = detailsData.consistency_analysis || {};
    const mostFoundFields = detailsData.most_found_fields_analysis || {};
    const recentPerf = detailsData.recent_performance || {};
    
    modalContent.innerHTML = `
        <div style="padding: 30px;">
            <!-- Header -->
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px; padding-bottom: 20px; border-bottom: 3px solid #3b82f6;">
                <h1 style="margin: 0; color: #1f2937; font-size: 28px;">
                    🤖 ${sanitizeHTML(modelId)}
                </h1>
                <button onclick="this.closest('.model-details-modal').remove()" 
                        style="background: #ef4444; color: white; border: none; padding: 10px 20px; border-radius: 8px; cursor: pointer; font-weight: bold; font-size: 16px;">
                    ✕ Schließen
                </button>
            </div>
            
            <!-- Key Metrics Row -->
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px; margin-bottom: 30px;">
                <div style="background: linear-gradient(135deg, #16a34a, #22c55e); color: white; padding: 20px; border-radius: 12px; text-align: center;">
                    <div style="font-size: 36px; font-weight: bold;">${(stats.success_rate * 100).toFixed(1)}%</div>
                    <div style="font-size: 14px; opacity: 0.9;">Erfolgsrate</div>
                </div>
                <div style="background: linear-gradient(135deg, #3b82f6, #60a5fa); color: white; padding: 20px; border-radius: 12px; text-align: center;">
                    <div style="font-size: 36px; font-weight: bold;">${stats.total_queries || 0}</div>
                    <div style="font-size: 14px; opacity: 0.9;">Gesamte Suchen</div>
                </div>
                <div style="background: linear-gradient(135deg, #8b5cf6, #a78bfa); color: white; padding: 20px; border-radius: 12px; text-align: center;">
                    <div style="font-size: 36px; font-weight: bold;">${consistency.overall_consistency?.toFixed(1) || 0}%</div>
                    <div style="font-size: 14px; opacity: 0.9;">Konsistenz</div>
                </div>
                <div style="background: linear-gradient(135deg, #f59e0b, #fbbf24); color: white; padding: 20px; border-radius: 12px; text-align: center;">
                    <div style="font-size: 36px; font-weight: bold;">${stats.data_quality_score?.toFixed(0) || 0}</div>
                    <div style="font-size: 14px; opacity: 0.9;">Qualitätsscore</div>
                </div>
            </div>
            
            <!-- Content Tabs -->
            <div style="margin-bottom: 20px;">
                <div style="display: flex; gap: 10px; margin-bottom: 20px;">
                    <button class="modal-tab-btn active" onclick="showModalTab('performance')"
                            style="background: #3b82f6; color: white; border: none; padding: 12px 20px; border-radius: 8px; cursor: pointer; font-weight: bold;">
                        📊 Performance
                    </button>
                    <button class="modal-tab-btn" onclick="showModalTab('consistency')"
                            style="background: #6b7280; color: white; border: none; padding: 12px 20px; border-radius: 8px; cursor: pointer; font-weight: bold;">
                        🎯 Konsistenz
                    </button>
                    <button class="modal-tab-btn" onclick="showModalTab('fields')"
                            style="background: #6b7280; color: white; border: none; padding: 12px 20px; border-radius: 8px; cursor: pointer; font-weight: bold;">
                        📋 Felder
                    </button>
                </div>
                
                <!-- Performance Tab -->
                <div id="tab-performance" class="modal-tab-content" style="display: block;">
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 30px;">
                        <div style="background: #f9fafb; padding: 25px; border-radius: 12px;">
                            <h3 style="margin-top: 0; color: #374151; font-size: 20px;">📈 Leistungsmetriken</h3>
                            <div style="space-y: 15px;">
                                <div style="display: flex; justify-content: space-between; padding: 10px 0; border-bottom: 1px solid #e5e7eb;">
                                    <span style="font-weight: 600;">Erfolgreiche Suchen:</span>
                                    <span style="color: #16a34a; font-weight: bold;">${stats.successful_queries || 0}</span>
                                </div>
                                <div style="display: flex; justify-content: space-between; padding: 10px 0; border-bottom: 1px solid #e5e7eb;">
                                    <span style="font-weight: 600;">Fehlgeschlagene Suchen:</span>
                                    <span style="color: #dc2626; font-weight: bold;">${stats.failed_queries || 0}</span>
                                </div>
                                <div style="display: flex; justify-content: space-between; padding: 10px 0; border-bottom: 1px solid #e5e7eb;">
                                    <span style="font-weight: 600;">Ø Response Zeit:</span>
                                    <span style="color: #3b82f6; font-weight: bold;">${stats.avg_response_time?.toFixed(0) || 0}ms</span>
                                </div>
                                <div style="display: flex; justify-content: space-between; padding: 10px 0; border-bottom: 1px solid #e5e7eb;">
                                    <span style="font-weight: 600;">Ø Feldabdeckung:</span>
                                    <span style="color: #8b5cf6; font-weight: bold;">${(stats.avg_field_coverage * 100 || 0).toFixed(1)}%</span>
                                </div>
                                <div style="display: flex; justify-content: space-between; padding: 10px 0;">
                                    <span style="font-weight: 600;">Gefundene Quellen:</span>
                                    <span style="color: #059669; font-weight: bold;">${stats.unique_sources_found || 0}</span>
                                </div>
                            </div>
                        </div>
                        
                        <div style="background: #f0f9ff; padding: 25px; border-radius: 12px;">
                            <h3 style="margin-top: 0; color: #0369a1; font-size: 20px;">📅 Aktuelle Performance</h3>
                            <div style="margin-bottom: 15px;">
                                <div style="font-weight: 600; margin-bottom: 10px;">Letzte 7 Tage:</div>
                                <div style="display: flex; justify-content: space-between; padding: 5px 0;">
                                    <span>Erfolgsrate:</span>
                                    <span style="font-weight: bold; color: #16a34a;">${(recentPerf.last_7_days?.success_rate * 100 || 0).toFixed(1)}%</span>
                                </div>
                                <div style="display: flex; justify-content: space-between; padding: 5px 0;">
                                    <span>Suchen:</span>
                                    <span style="font-weight: bold;">${recentPerf.last_7_days?.total_queries || 0}</span>
                                </div>
                            </div>
                            <div>
                                <div style="font-weight: 600; margin-bottom: 10px;">Letzte 30 Tage:</div>
                                <div style="display: flex; justify-content: space-between; padding: 5px 0;">
                                    <span>Erfolgsrate:</span>
                                    <span style="font-weight: bold; color: #16a34a;">${(recentPerf.last_30_days?.success_rate * 100 || 0).toFixed(1)}%</span>
                                </div>
                                <div style="display: flex; justify-content: space-between; padding: 5px 0;">
                                    <span>Suchen:</span>
                                    <span style="font-weight: bold;">${recentPerf.last_30_days?.total_queries || 0}</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                
                <!-- Consistency Tab -->
                <div id="tab-consistency" class="modal-tab-content" style="display: none;">
                    <div style="background: #fefce8; padding: 25px; border-radius: 12px; margin-bottom: 20px;">
                        <h3 style="margin-top: 0; color: #a16207; font-size: 20px;">🎯 Konsistenz-Analyse</h3>
                        <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 20px; margin-bottom: 20px;">
                            <div style="text-align: center; padding: 15px; background: white; border-radius: 8px;">
                                <div style="font-size: 24px; font-weight: bold; color: #16a34a;">${consistency.overall_consistency?.toFixed(1) || 0}%</div>
                                <div style="font-size: 14px; color: #6b7280;">Gesamtkonsistenz</div>
                            </div>
                            <div style="text-align: center; padding: 15px; background: white; border-radius: 8px;">
                                <div style="font-size: 24px; font-weight: bold; color: #3b82f6;">${consistency.total_mine_comparisons || 0}</div>
                                <div style="font-size: 14px; color: #6b7280;">Minen verglichen</div>
                            </div>
                            <div style="text-align: center; padding: 15px; background: white; border-radius: 8px;">
                                <div style="font-size: 20px; font-weight: bold; color: #8b5cf6;">${consistency.consistency_grade || 'N/A'}</div>
                                <div style="font-size: 14px; color: #6b7280;">Bewertung</div>
                            </div>
                        </div>
                        
                        <div style="background: white; padding: 20px; border-radius: 8px;">
                            <h4 style="margin-top: 0; color: #374151;">🔍 Feld-spezifische Konsistenz:</h4>
                            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 10px;">
                                ${Object.entries(consistency.field_consistency || {}).map(([field, data]) => `
                                    <div style="background: #f9fafb; padding: 12px; border-radius: 6px; border-left: 4px solid ${getConsistencyColor(data.consistency_percent)};">
                                        <div style="font-weight: bold; font-size: 12px; color: #374151;">${sanitizeHTML(field)}</div>
                                        <div style="font-size: 16px; font-weight: bold; color: ${getConsistencyColor(data.consistency_percent)};">${data.consistency_percent?.toFixed(1) || 0}%</div>
                                        <div style="font-size: 11px; color: #6b7280;">${data.matches || 0}/${data.total_comparisons || 0} Matches</div>
                                    </div>
                                `).join('')}
                            </div>
                        </div>
                    </div>
                </div>
                
                <!-- Fields Tab -->
                <div id="tab-fields" class="modal-tab-content" style="display: none;">
                    <div style="background: #f0fdf4; padding: 25px; border-radius: 12px;">
                        <h3 style="margin-top: 0; color: #166534; font-size: 20px;">📋 Top-Performance Felder</h3>
                        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 15px;">
                            ${(mostFoundFields.top_fields || []).map(fieldData => `
                                <div style="background: white; padding: 20px; border-radius: 10px; border-left: 5px solid #16a34a;">
                                    <div style="font-weight: bold; font-size: 16px; color: #374151; margin-bottom: 10px;">
                                        ${sanitizeHTML(fieldData.field)}
                                    </div>
                                    <div style="margin-bottom: 8px;">
                                        <div style="display: flex; justify-content: space-between;">
                                            <span style="color: #6b7280; font-size: 14px;">Erfolgsrate:</span>
                                            <span style="font-weight: bold; color: #16a34a;">${fieldData.success_rate?.toFixed(1) || 0}%</span>
                                        </div>
                                    </div>
                                    <div style="margin-bottom: 8px;">
                                        <div style="display: flex; justify-content: space-between;">
                                            <span style="color: #6b7280; font-size: 14px;">Gefunden:</span>
                                            <span style="font-weight: bold; color: #3b82f6;">${fieldData.found_count || 0}</span>
                                        </div>
                                    </div>
                                    <div>
                                        <div style="display: flex; justify-content: space-between;">
                                            <span style="color: #6b7280; font-size: 14px;">Qualität:</span>
                                            <span style="font-weight: bold; color: #8b5cf6;">${(fieldData.avg_quality * 100 || 0).toFixed(0)}%</span>
                                        </div>
                                    </div>
                                </div>
                            `).join('')}
                        </div>
                    </div>
                </div>
            </div>
        </div>
    `;
    
    modal.appendChild(modalContent);
    document.body.appendChild(modal);
    
    // Click außerhalb schließt Modal
    modal.addEventListener('click', (e) => {
        if (e.target === modal) {
            modal.remove();
        }
    });
    
    console.log('✅ [MODAL] Model details modal displayed');
}

/**
 * NEUE FUNKTION: Wechselt zwischen Modal-Tabs
 */
window.showModalTab = function(tabName) {
    // Verstecke alle Tabs
    const tabs = document.querySelectorAll('.modal-tab-content');
    tabs.forEach(tab => tab.style.display = 'none');
    
    // Zeige ausgewählten Tab
    const targetTab = document.getElementById(`tab-${tabName}`);
    if (targetTab) {
        targetTab.style.display = 'block';
    }
    
    // Update Button-Styling
    const buttons = document.querySelectorAll('.modal-tab-btn');
    buttons.forEach(btn => {
        btn.style.background = '#6b7280';
    });
    
    const activeBtn = event.target;
    if (activeBtn) {
        activeBtn.style.background = '#3b82f6';
    }
};

/**
 * NEUE FUNKTION: Exportiert Modell-Statistiken als CSV
 */
window.exportModelStatistics = function() {
    console.log('📊 [CSV-EXPORT] Starting model statistics export');
    showNotification('📊 Exportiere Modell-Statistiken...', 'info');
    
    // Hole aktuelle Daten aus der Tabelle
    const table = document.querySelector('.consolidated-table');
    if (!table) {
        showNotification('❌ Keine Tabellendaten zum Exportieren gefunden', 'error');
        return;
    }
    
    const rows = table.querySelectorAll('tbody tr');
    let csvContent = 'Modell,Provider,Erfolgsrate,Gefundene_Felder,Konsistenz,Performance_Kategorie,Qualitaetsscore,Anzahl_Suchen\n';
    
    rows.forEach(row => {
        const cells = row.querySelectorAll('td');
        if (cells.length >= 8) {
            const modelName = cells[0].textContent.trim().split('\n')[0];
            const provider = cells[1].textContent.trim();
            const successRate = cells[2].textContent.trim().replace('%', '');
            const fieldsFound = cells[3].textContent.trim().split('\n')[0];
            const consistency = cells[4].textContent.trim().replace('%', '');
            const performanceCategory = cells[5].textContent.trim();
            const qualityScore = cells[6].textContent.trim().split('\n')[0];
            const totalSearches = cells[7].textContent.trim().split('\n')[0];
            
            csvContent += `"${modelName}","${provider}",${successRate},${fieldsFound},${consistency},"${performanceCategory}",${qualityScore},${totalSearches}\n`;
        }
    });
    
    // Download CSV
    const blob = new Blob([csvContent], { type: 'text/csv;charset=utf-8;' });
    const link = document.createElement('a');
    const timestamp = new Date().toISOString().replace(/[:.]/g, '-');
    link.download = `modell_statistiken_${timestamp}.csv`;
    link.href = window.URL.createObjectURL(blob);
    link.click();
    
    showNotification('✅ Modell-Statistiken erfolgreich exportiert', 'success');
    console.log('✅ [CSV-EXPORT] Model statistics exported successfully');
};

/**
 * HILFSFUNKTIONEN: Farbkodierung für verschiedene Metriken
 */
function getPerformanceCategoryColor(category) {
    const colorMap = {
        'Excellent': '#16a34a',
        'Very Good': '#22c55e',
        'Good': '#65a30d',
        'Fair': '#f59e0b',
        'Poor': '#f97316',
        'Very Poor': '#dc2626'
    };
    return colorMap[category] || '#6b7280';
}

function getConsistencyColor(consistency) {
    if (consistency >= 90) return '#16a34a';
    if (consistency >= 80) return '#22c55e';
    if (consistency >= 70) return '#f59e0b';
    if (consistency >= 50) return '#f97316';
    return '#dc2626';
}

function getQualityColor(quality) {
    if (quality >= 90) return '#16a34a';
    if (quality >= 80) return '#22c55e';
    if (quality >= 70) return '#f59e0b';
    if (quality >= 60) return '#f97316';
    return '#dc2626';
}

// ÄNDERUNG 10.08.2025: Tab-Switch-Handler nach event-handlers.js extrahiert

// ÄNDERUNG 10.08.2025: HTMX-Timer-Integration nach event-handlers.js extrahiert

// ÄNDERUNG 10.08.2025: showTemporaryMessage nach helpers.js extrahiert

// Verbesserte cancelSearch Funktion
function cancelSearch() {
    console.log('🛑 Suche wird abgebrochen');
    if (typeof stopSearchTimer === 'function') {
        stopSearchTimer(); // Verwende helpers.js Funktion
    }
    
    // HTMX Request abbrechen
    if (window.htmx) {
        // Alle laufenden Requests abbrechen
        const activeRequests = document.querySelectorAll('[hx-request]');
        activeRequests.forEach(el => {
            htmx.remove(el, 'hx-request');
        });
    }
    
    // Ladeindikator ausblenden
    const loadingIndicator = document.getElementById('loading');
    if (loadingIndicator) {
        loadingIndicator.style.display = 'none';
    }
    
    showTemporaryMessage('🛑 Suche wurde abgebrochen', 'info');
}

// CSS für Pulse-Animation hinzufügen
const pulseStyles = document.createElement('style');
pulseStyles.textContent = `
    @keyframes pulse {
        0%, 100% { opacity: 1; transform: scale(1); }
        50% { opacity: 0.7; transform: scale(1.05); }
    }
    
    .loading-enhanced {
        background: linear-gradient(135deg, #f0f9ff 0%, #e0e7ff 100%);
        border: 2px solid #3b82f6;
        border-radius: 12px;
        box-shadow: 0 8px 25px rgba(59, 130, 246, 0.15);
    }
    
    .spinner {
        border-color: #3b82f6 transparent #3b82f6 transparent;
        animation: spin 1s linear infinite;
    }
    
    @keyframes spin {
        0% { transform: rotate(0deg); }
        100% { transform: rotate(360deg); }
    }
    
    @keyframes progress-pulse {
        0%, 100% { 
            transform: translateX(-100%); 
            opacity: 0.3; 
        }
        50% { 
            transform: translateX(300%); 
            opacity: 1; 
        }
    }
`;
document.head.appendChild(pulseStyles);

// MineSearch v2.1 - Enhanced JavaScript with CSV export, UI Testing, and improved Timer system initialized

// ============================================
// TAB AUTO-LOADING SYSTEM
// ============================================

/**
 * Auto-Loading System für Tab-Inhalte
 * Lädt automatisch Daten beim ersten Besuch eines Tabs
 */
const TabAutoLoader = {
    loadedTabs: new Set(['single']), // Single-Tab ist default geladen
    
    /**
     * Initialisiert das Auto-Loading-System
     */
    initialize() {
        console.log('🔄 [TAB-AUTOLOADER] Initializing tab auto-loading system...');
        
        // Event Listener für alle Tab Radio Buttons
        const tabInputs = document.querySelectorAll('.tab-navigation input[type="radio"]');
        tabInputs.forEach(tabInput => {
            tabInput.addEventListener('change', (e) => {
                if (e.target.checked) {
                    this.handleTabChange(e.target.id);
                }
            });
        });
        
        // Initial load für default tab
        this.handleTabChange('single-tab');
    },
    
    /**
     * Behandelt Tab-Wechsel und triggert Auto-Loading
     */
    handleTabChange(tabId) {
        const tabName = tabId.replace('-tab', '');
        console.log(`🔄 [TAB-AUTOLOADER] Switching to tab: ${tabName}`);
        
        // Update CSS-Klassen für Tab-Anzeige
        this.updateTabDisplay(tabName);
        
        // Prüfe ob Tab bereits geladen wurde
        if (!this.loadedTabs.has(tabName)) {
            console.log(`📥 [TAB-AUTOLOADER] First visit to ${tabName} tab - auto-loading data...`);
            this.loadTabData(tabName);
            this.loadedTabs.add(tabName);
        } else {
            console.log(`✅ [TAB-AUTOLOADER] Tab ${tabName} already loaded`);
        }
    },
    
    /**
     * Aktualisiert CSS-Klassen für Tab-Display
     */
    updateTabDisplay(activeTabName) {
        const container = document.querySelector('.container');
        if (!container) return;
        
        // Entferne alle Tab-Klassen
        const tabClasses = ['tab-single', 'tab-csv', 'tab-sources', 'tab-statistics', 'tab-consolidated'];
        container.classList.remove(...tabClasses);
        
        // Füge aktive Tab-Klasse hinzu
        container.classList.add(`tab-${activeTabName}`);
        console.log(`🎨 [TAB-AUTOLOADER] Set container class to: tab-${activeTabName}`);
        
        // SPEZIAL-FIX für konsolidierte Ansicht - erzwinge Sichtbarkeit
        if (activeTabName === 'consolidated') {
            const consolidatedForm = document.getElementById('consolidated_form');
            if (consolidatedForm) {
                consolidatedForm.style.display = 'block';
                consolidatedForm.style.visibility = 'visible';
                consolidatedForm.style.opacity = '1';
                console.log(`🔧 [TAB-AUTOLOADER] Forced visibility for consolidated_form`);
            }
        }
    },
    
    /**
     * Lädt Daten für einen spezifischen Tab
     */
    loadTabData(tabName) {
        switch(tabName) {
            case 'sources':
                console.log('📚 [TAB-AUTOLOADER] Loading sources data...');
                if (typeof loadSources === 'function') {
                    loadSources();
                } else {
                    console.error('❌ [TAB-AUTOLOADER] loadSources function not found');
                }
                break;
                
            case 'statistics':
                console.log('📊 [TAB-AUTOLOADER] Loading statistics data...');
                if (typeof loadModelStatistics === 'function') {
                    loadModelStatistics();
                } else {
                    console.error('❌ [TAB-AUTOLOADER] loadModelStatistics function not found');
                }
                break;
                
            case 'consolidated':
                console.log('📋 [TAB-AUTOLOADER] Loading consolidated results...');
                if (typeof loadConsolidatedResults === 'function') {
                    loadConsolidatedResults();
                } else {
                    console.error('❌ [TAB-AUTOLOADER] loadConsolidatedResults function not found');
                }
                break;
                
            case 'csv':
                console.log('📊 [TAB-AUTOLOADER] CSV tab - no auto-loading needed');
                break;
                
            case 'single':
                console.log('🔍 [TAB-AUTOLOADER] Single search tab - no auto-loading needed');
                break;
                
            default:
                console.warn(`⚠️ [TAB-AUTOLOADER] Unknown tab: ${tabName}`);
        }
    }
};

// Initialisiere Auto-Loading nach DOM-Load
if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => {
        TabAutoLoader.initialize();
    });
} else {
    TabAutoLoader.initialize();
}

console.log('🔄 [TAB-AUTOLOADER] Tab Auto-Loading System initialized');

</script>

</body>
</html>
