                    <div><strong>Erster Test:</strong> ${stats.first_test_at ? new Date(stats.first_test_at).toLocaleDateString('de-DE') : 'N/A'}</div>
                    <div style="margin-top: 10px;"><strong>Letzter Test:</strong> ${stats.last_test_at ? new Date(stats.last_test_at).toLocaleDateString('de-DE') : 'N/A'}</div>
