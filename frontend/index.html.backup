                            📈 Score Analysis
                        </button>
                        <button onclick="toggleAnalyticsView('usage', '${domain}')" class="analytics-btn" data-view="usage" style="background: #e0e0e0; color: #333; border: none; padding: 8px 16px; border-radius: 6px; cursor: pointer; font-size: 12px; transition: all 0.2s;">
                            🎯 Usage Trends
                        </button>
                        <button onclick="toggleAnalyticsView('performance', '${domain}')" class="analytics-btn" data-view="performance" style="background: #e0e0e0; color: #333; border: none; padding: 8px 16px; border-radius: 6px; cursor: pointer; font-size: 12px; transition: all 0.2s;">
                            ⚡ Performance
                        </button>
                    </div>
                </div>

                <!-- Score Analysis View -->
                <div id="analytics-score-${domain}" class="analytics-view active">
                    ${generateScoreAnalysisView(scoreBreakdown, sources)}
                </div>

                <!-- Usage Trends View -->
                <div id="analytics-usage-${domain}" class="analytics-view" style="display: none;">
