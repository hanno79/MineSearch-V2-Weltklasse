// Auto-refresh functions
function startAutoRefresh(tabType) {
    // Stop existing auto-refresh
    stopAutoRefresh();
    
    console.log(`Starting auto-refresh for ${tabType} tab (every ${AUTO_REFRESH_INTERVAL/1000}s)`);
    
    autoRefreshInterval = setInterval(() => {
        console.log(`Auto-refreshing ${tabType} data...`);
        
        switch(tabType) {
            case 'sources':
                loadSources();
                break;
            case 'statistics':
                loadStatistics();
                break;
            case 'results':
                loadResults();
                break;
            case 'consolidated':
                loadConsolidatedResults();
                break;
        }
    }, AUTO_REFRESH_INTERVAL);
}

function stopAutoRefresh() {
    if (autoRefreshInterval) {
        console.log('Stopping auto-refresh');
        clearInterval(autoRefreshInterval);
        autoRefreshInterval = null;
    }
}

// Stop auto-refresh when user is inactive - userInactivityTimer und INACTIVITY_TIMEOUT werden aus auto-refresh.js importiert

function resetInactivityTimer() {
    clearTimeout(userInactivityTimer);
    userInactivityTimer = setTimeout(() => {
        console.log('User inactive, stopping auto-refresh');
        stopAutoRefresh();
    }, INACTIVITY_TIMEOUT);
}

// Listen for user activity
document.addEventListener('click', resetInactivityTimer);
document.addEventListener('keypress', resetInactivityTimer);
document.addEventListener('scroll', resetInactivityTimer);
document.addEventListener('mousemove', resetInactivityTimer);

// Stop auto-refresh when page becomes hidden
document.addEventListener('visibilitychange', () => {
    if (document.hidden) {
        console.log('Page hidden, stopping auto-refresh');
        stopAutoRefresh();
    } else {
        console.log('Page visible, checking for tab to restart auto-refresh');
        const activeTab = document.querySelector('input[name="tab"]:checked');
        if (activeTab) {
            startAutoRefresh(activeTab.value);
        }
    }
});

// Result-Restoration Funktion
function restoreResultsIfAvailable() {
    const savedResults = sessionStorage.getItem('lastSearchResults');
    const savedBatchHTML = sessionStorage.getItem('lastBatchHTML');
    const savedTimestamp = sessionStorage.getItem('lastSearchTimestamp');
    
    if (savedResults || savedBatchHTML) {
        try {
            const timestamp = new Date(savedTimestamp);
            const minutesAgo = Math.floor((new Date() - timestamp) / 1000 / 60);
            
            if (minutesAgo < 30) {
                const resultsDiv = document.getElementById('results');
                
                if (!resultsDiv.innerHTML.trim() || resultsDiv.innerHTML.includes('Keine Suchergebnisse')) {
                    if (savedBatchHTML) {
                        resultsDiv.innerHTML = savedBatchHTML;
                        console.log('✅ Batch-HTML wiederhergestellt');
                    } else if (savedResults) {
                        const results = JSON.parse(savedResults);
                        console.log('✅ JSON-Results wiederhergestellt');
                        displayResults(results);
                    }
                }
            }
        } catch (e) {
            console.error('Fehler beim Wiederherstellen der Ergebnisse:', e);
        }
    }
}

