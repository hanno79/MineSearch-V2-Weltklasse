                            <button onclick="refreshDomainDetails(${safeJSONStringify(domain)})" title="Daten aktualisieren" style="background: rgba(255,255,255,0.2); border: none; color: white; padding: 8px 12px; border-radius: 6px; cursor: pointer; font-size: 12px; transition: all 0.2s;">
