            <!-- Sources Section -->
            <div class="sources-section" style="background: white; border-radius: 12px; padding: 25px; box-shadow: 0 4px 6px rgba(0,0,0,0.07);">
                <div class="section-header" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; border-bottom: 2px solid #f0f0f0; padding-bottom: 15px;">
                    <h4 style="margin: 0; color: #333; font-size: 18px; font-weight: 600;">📋 Quellen-Details (${totalSources})</h4>
                    <div class="view-controls" style="display: flex; gap: 8px;">
                        <select onchange="sortSources('${domain}', this.value)" style="padding: 6px 10px; border: 1px solid #ddd; border-radius: 4px; font-size: 12px;">
                            <option value="reliability">Nach Reliability</option>
                            <option value="usage">Nach Nutzung</option>
                            <option value="name">Nach Name</option>
                            <option value="country">Nach Land</option>
                        </select>
                        <button onclick="toggleSourceView('list', '${domain}')" class="view-btn active" data-view="list" style="background: #4CAF50; color: white; border: none; padding: 6px 12px; border-radius: 4px; cursor: pointer; font-size: 12px;">📄 Liste</button>
                        <button onclick="toggleSourceView('grid', '${domain}')" class="view-btn" data-view="grid" style="background: #e0e0e0; color: #333; border: none; padding: 6px 12px; border-radius: 4px; cursor: pointer; font-size: 12px;">⚏ Grid</button>
                    </div>
