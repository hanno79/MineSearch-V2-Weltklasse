    <script>
// Enhanced JavaScript for MineSearch v2.1
// Combines working core functionality with complete database display functions

// ÄNDERUNG 10.08.2025: API_BASE_URL jetzt in api.js definiert - Duplikat entfernt

// ÄNDERUNG 10.08.2025: Funktionen nach utils.js extrahiert
// sanitizeHTML, detectFieldType sind jetzt in utils.js verfügbar

// ÄNDERUNG 10.08.2025: escapeJavaScriptString und safeJSONStringify nach helpers.js extrahiert

// ÄNDERUNG 10.08.2025: safeSetHTML nach helpers.js extrahiert

// PERFORMANCE-FIX: Hilfsfunktionen für wiederverwendbare UI-Elemente
// TIMER-FIX 09.08.2025: Timer-System wird aus utils.js importiert

function createLoadingHTML(title, message = '', showSpinner = true, showTimer = false) {
    const spinnerHTML = showSpinner ? `
        <div style="margin-top: 10px;">
            <div style="display: inline-block; width: 20px; height: 20px; border: 3px solid #f3f3f3; border-top: 3px solid #0ea5e9; border-radius: 50%; animation: spin 1s linear infinite;"></div>
        </div>
    ` : '';
    
    const timerHTML = showTimer ? `
        <p class="search-timer" style="font-weight: bold; color: #2563eb; font-size: 20px; margin: 10px 0;">00:00</p>
    ` : '';
    
    return `
        <div style="padding: 20px; text-align: center; background: #f0f9ff; border-radius: 8px; border: 1px solid #0ea5e9;">
            <h3>${sanitizeHTML(title)}</h3>
            ${message ? `<p>${sanitizeHTML(message)}</p>` : ''}
            ${timerHTML}
            ${spinnerHTML}
        </div>
    `;
}

// ENTFERNT 11.08.2025: Veraltete Timer-Funktionen - wird jetzt von utils.js und helpers.js bereitgestellt

function createErrorHTML(title, message = '') {
    return `
        <div style="padding: 20px; text-align: center; background: #fef2f2; border-radius: 8px; border: 1px solid #f87171;">
            <h3 style="color: #dc2626;">${sanitizeHTML(title)}</h3>
            ${message ? `<p style="color: #dc2626;">${sanitizeHTML(message)}</p>` : ''}
        </div>
    `;
}

// Helper functions for field difficulty analysis
function getFieldDifficulty(successRate) {
    if (successRate >= 80) {
        return { label: "Sehr Einfach", color: "#28a745", description: "Wird fast immer gefunden" };
    } else if (successRate >= 60) {
        return { label: "Einfach", color: "#007bff", description: "Meist erfolgreich gefunden" };
    } else if (successRate >= 40) {
        return { label: "Mittel", color: "#ffc107", description: "Moderate Erfolgsrate" };
    } else if (successRate >= 20) {
        return { label: "Schwer", color: "#fd7e14", description: "Niedrige Erfolgsrate" };
    } else {
        return { label: "Sehr Schwer", color: "#dc3545", description: "Selten erfolgreich" };
    }
}

function exportModelData(modelId) {
    console.log(`📊 Exporting data for model: ${modelId}`);
    showNotification('📊 Model-Daten werden exportiert...', 'info');
    
    // Export als CSV über API
    const exportUrl = `${window.window.API_BASE_URL}/api/statistics/export/csv?table=models&model_id=${encodeURIComponent(modelId)}&days_back=30`;
    
    // Erstelle unsichtbaren Download-Link
    const link = document.createElement('a');
    link.href = exportUrl;
    link.download = `model_${modelId}_statistics.csv`;
    link.style.display = 'none';
    document.body.appendChild(link);
    link.click();
    document.body.removeChild(link);
    
    showNotification('✅ Model-Daten erfolgreich exportiert', 'success');
}

function exportFieldData(modelId = null) {
    console.log(`📊 Exporting field data for model: ${modelId || 'all'}`);
    showNotification('📊 Feld-Daten werden exportiert...', 'info');
    
    // Export als CSV über API
    let exportUrl = `${window.window.API_BASE_URL}/api/statistics/export/csv?table=fields&days_back=30`;
    if (modelId) {
        exportUrl += `&model_id=${encodeURIComponent(modelId)}`;
    }
    
    // Erstelle unsichtbaren Download-Link
    const link = document.createElement('a');
    link.href = exportUrl;
    link.download = `field_statistics${modelId ? '_' + modelId : ''}.csv`;
    link.style.display = 'none';
    document.body.appendChild(link);
    link.click();
    document.body.removeChild(link);
    
    showNotification('✅ Feld-Daten erfolgreich exportiert', 'success');
}

// ÄNDERUNG 10.08.2025: closeModelDetails und closeFieldPerformance nach ui.js extrahiert

function showErrorMessage(element, title, message = '') {
    element.innerHTML = createErrorHTML(title, message);
}

function createSuccessMessage(title, message = '') {
    const msgElement = document.createElement('div');
    msgElement.style.cssText = 'background: #10b981; color: white; padding: 10px; border-radius: 5px; margin-bottom: 15px; text-align: center;';
    msgElement.innerHTML = `✅ ${sanitizeHTML(title)}${message ? ` - ${sanitizeHTML(message)}` : ''}`;
    return msgElement;
}

// PERFORMANCE-FIX: DocumentFragment für effiziente DOM-Manipulationen
function createDocumentFragment() {
    return document.createDocumentFragment();
}

function appendToFragment(fragment, element) {
    fragment.appendChild(element);
}

function replaceContentWithFragment(container, fragment) {
    container.innerHTML = '';
    container.appendChild(fragment);
}

// EVENT COORDINATION AGENT: Global State Management and Event Coordination
// loadSourcesInProgress und loadSourcesAbortController werden aus display.js importiert
let benchmarkSessionId = null;
let benchmarkCheckInterval = null;

// Enhanced Global State for UI Coordination
let uiCoordinationState = {
    activeDetails: new Set(), // Track open details accordions
    sortingInProgress: false,
    lastInteraction: Date.now(),
    eventQueue: [],
    preventConflicts: false
};

// ============================================
// GRACEFUL ERROR DISPLAY SYSTEM
// ============================================

/**
 * Zentrale Graceful Error Handler Funktion
 * Ersetzt console.error mit benutzerfreundlichen UI-Meldungen
 */
function showGracefulError(errorType, message, targetElement = null, showRetry = false, retryCallback = null) {
    // Sammle Error-Details für Debugging (intern)
    const errorDetails = {
        type: errorType,
        message: message,
        timestamp: new Date().toISOString(),
        url: window.location.href
    };
    
    // Intern loggen für Entwickler (weiterhin in Console)
    console.warn('Graceful Error Handler:', errorDetails);
    
    // Erstelle benutzerfreundliche Fehlermeldung
    let userMessage = '';
    let icon = '⚠️';
    
    switch(errorType) {
        case 'API_ERROR':
            userMessage = 'Verbindung zum Server fehlgeschlagen. Bitte versuchen Sie es später erneut.';
            icon = '🔌';
            break;
        case 'LOAD_ERROR':
            userMessage = 'Daten konnten nicht geladen werden. Möglicherweise ist der Service temporär nicht verfügbar.';
            icon = '📡';
            break;
        case 'SOURCE_NOT_FOUND':
            userMessage = 'Keine Details für diese Quelle verfügbar.';
            icon = '📋';
            break;
        case 'TIMEOUT_ERROR':
            userMessage = 'Die Anfrage dauerte zu lange. Bitte versuchen Sie es erneut.';
            icon = '⏰';
            break;
        case 'NETWORK_ERROR':
            userMessage = 'Netzwerkverbindung unterbrochen. Prüfen Sie Ihre Internetverbindung.';
            icon = '🌐';
            break;
        case 'SUCCESS':
            userMessage = message; // Use the provided message directly
            icon = '✅';
            break;
        default:
            userMessage = 'Ein unerwarteter Fehler ist aufgetreten. Bitte laden Sie die Seite neu.';
            icon = '❌';
    }
    
    // Erstelle Error-HTML mit optionalem Retry-Button
    const retryButtonHTML = showRetry && retryCallback ? `
        <button onclick="(${retryCallback.toString()})()" 
                style="background: #4CAF50; color: white; border: none; padding: 8px 16px; border-radius: 4px; margin-top: 10px; cursor: pointer;">
            🔄 Erneut versuchen
        </button>
    ` : '';
    
    // Dynamic styling based on error type
    const isSuccess = errorType === 'SUCCESS';
    const backgroundColor = isSuccess ? '#d4edda' : '#fff3cd';
    const borderColor = isSuccess ? '#c3e6cb' : '#ffeaa7';
    const leftBorderColor = isSuccess ? '#28a745' : '#f39c12';
    const textColor = isSuccess ? '#155724' : '#856404';
    const titleText = isSuccess ? 'Erfolg' : 'Hinweis';
    
    const errorHTML = `
        <div class="graceful-error" style="
            padding: 20px; 
            text-align: center; 
            background: ${backgroundColor}; 
            border: 1px solid ${borderColor}; 
            border-radius: 8px; 
            margin: 10px 0;
            border-left: 4px solid ${leftBorderColor};
        ">
            <div style="font-size: 24px; margin-bottom: 10px;">${icon}</div>
            <h3 style="color: ${textColor}; margin: 0 0 10px 0;">${titleText}</h3>
            <p style="color: ${textColor}; margin: 0;">${userMessage}</p>
            ${retryButtonHTML}
        </div>
    `;
    
    // Zeige Error in spezifiziertem Element oder erstelle Notification
    if (targetElement) {
        targetElement.innerHTML = errorHTML;
    } else {
        showNotification(userMessage, 'warning', icon);
    }
}

/**
 * Verbesserte Notification-Funktion mit Icons
 */
// ÄNDERUNG 10.08.2025: showNotification nach helpers.js extrahiert

/**
 * Verbesserte "Keine Details verfügbar" Fallback-Funktion
 */
function showNoDetailsAvailable(targetElement, domain = null) {
    const domainText = domain ? ` für ${domain}` : '';
    const fallbackHTML = `
        <div class="no-details-fallback" style="
            padding: 30px; 
            text-align: center; 
            background: #f8f9fa; 
            border: 2px dashed #dee2e6; 
            border-radius: 8px; 
            color: #6c757d;
        ">
            <div style="font-size: 48px; margin-bottom: 15px;">📭</div>
            <h3 style="color: #495057; margin-bottom: 10px;">Keine Details verfügbar</h3>
            <p>Für diese Quelle${domainText} sind derzeit keine detaillierten Informationen verfügbar.</p>
            <small style="color: #868e96;">Dies kann vorkommen, wenn die Quelle noch nicht vollständig analysiert wurde.</small>
        </div>
    `;
    
    if (targetElement) {
        targetElement.innerHTML = fallbackHTML;
    }
}

/**
 * Enhanced Loading State mit besserer UX
 */
function showEnhancedLoadingState(targetElement, message = 'Daten werden geladen...', showProgress = false) {
    // Kann erweitert werden um Progress-Bar falls showProgress = true
    const progressHTML = showProgress ? `
        <div style="width: 100%; background: #e9ecef; border-radius: 10px; margin-top: 15px; height: 6px;">
            <div style="width: 0%; height: 100%; background: #4CAF50; border-radius: 10px; animation: loading-progress 2s ease-in-out infinite;"></div>
        </div>
        <style>
        @keyframes loading-progress {
            0% { width: 0%; }
            50% { width: 70%; }
            100% { width: 0%; }
        }
        </style>
    ` : '';
    
    const loadingHTML = `
        <div class="enhanced-loading" style="
            padding: 40px; 
            text-align: center; 
            background: #f0f9ff; 
            border-radius: 8px; 
            border: 1px solid #0ea5e9;
        ">
            <div style="display: inline-block; width: 32px; height: 32px; border: 3px solid #f3f3f3; border-top: 3px solid #0ea5e9; border-radius: 50%; animation: spin 1s linear infinite; margin-bottom: 15px;"></div>
            <h3 style="color: #0369a1; margin-bottom: 10px;">Einen Moment bitte...</h3>
            <p style="color: #0369a1;">${message}</p>
            ${progressHTML}
        </div>
    `;
    
    if (targetElement) {
        targetElement.innerHTML = loadingHTML;
    }
}

// EVENT CONFLICT PREVENTION SYSTEM
function preventEventConflicts(eventType, handler) {
    return function(...args) {
        if (uiCoordinationState.preventConflicts) {
            console.log(`⚠️ Event ${eventType} blocked - conflicts prevented`);
            return;
        }
        
        uiCoordinationState.lastInteraction = Date.now();
        
        try {
            return handler.apply(this, args);
        } catch (error) {
            console.error(`❌ Event ${eventType} error:`, error);
        }
    };
}

// ENHANCED EVENT COORDINATION WRAPPER
function coordinateUIEvent(eventName, eventHandler) {
    return preventEventConflicts(eventName, async function(...args) {
        console.log(`🎯 UI Event: ${eventName} started`);
        
        // Add to event queue for debugging
        uiCoordinationState.eventQueue.push({
            name: eventName,
            timestamp: Date.now(),
            args: args.length
        });
        
        // Keep only last 10 events
        if (uiCoordinationState.eventQueue.length > 10) {
            uiCoordinationState.eventQueue.shift();
        }
        
        try {
            const result = await eventHandler.apply(this, args);
            console.log(`✅ UI Event: ${eventName} completed`);
            return result;
        } catch (error) {
            console.error(`❌ UI Event: ${eventName} failed:`, error);
            throw error;
        }
    });
}

// SORTING-FIX 23.07.2025: Sortier-State für Toggle-Funktionalität
let currentSortBy = 'count';
let currentSortOrder = 'desc';

// Auto-refresh configuration - autoRefreshInterval und AUTO_REFRESH_INTERVAL werden aus auto-refresh.js importiert

// CENTRAL INITIALIZATION: Koordinierte Initialisierung aller Module
document.addEventListener('DOMContentLoaded', function() {
    console.log('🚀 [MAIN-INIT] MineSearch v2.0 - Central initialization starting...');
    
    // PHASE 1: Module loading verification with retry logic
    function initializeModules(attempt = 1, maxAttempts = 5) {
        console.log(`📋 [MAIN-INIT] Phase 1: Verifying module loads (attempt ${attempt}/${maxAttempts})...`);
        
        const moduleStatus = {
            helpers: typeof showNotification === 'function',
            search: typeof loadModelsForFilter === 'function',
            ui: typeof toggleProviderModels === 'function',
            api: typeof window.ModelsAPI === 'object',
            eventHandlers: typeof initializeEventHandlers === 'function'
        };
        
        console.log('📊 [MAIN-INIT] Module status:', moduleStatus);
        
        // Check if critical modules are loaded
        if (moduleStatus.search && moduleStatus.helpers && moduleStatus.api) {
            console.log('🔄 [MAIN-INIT] Phase 2: All modules ready - Loading models...');
            loadModelsForFilter();
            
            // PHASE 3: Component initialization
            setTimeout(() => {
                console.log('⚙️ [MAIN-INIT] Phase 3: Component initialization...');
                
                // Initialize deduplication engine check
                if (!window.deduplicationEngine) {
                    console.warn('⚠️ [DEDUPLICATION] Engine not loaded');
                } else {
                    console.log('✅ [DEDUPLICATION] Engine ready');
                }
                
                console.log('✅ [MAIN-INIT] Central initialization complete');
            }, 500);
        } else {
            console.warn(`⚠️ [MAIN-INIT] Some modules not ready yet (attempt ${attempt}/${maxAttempts})`);
            
            if (attempt < maxAttempts) {
                // Retry with exponential backoff
                setTimeout(() => initializeModules(attempt + 1, maxAttempts), attempt * 1000);
            } else {
                console.error('❌ [MAIN-INIT] Module loading failed after maximum attempts!');
                console.error('❌ [MAIN-INIT] Search module not loaded - cannot load models!');
            }
        }
    }
    
    // Start initialization with delay to allow modules to load
    setTimeout(initializeModules, 2000);
    
    // ENTFERNT: loadTestCSV() verursachte 404-Error für test_mines_quebec.csv
    
    // Tab system validation (simplified)
    console.log('📑 [MAIN-INIT] Tab system check...');
    
    // LEGACY TAB HANDLER HINWEIS: Diese Funktionalität wird vom event-handlers.js Modul übernommen
    console.log('📑 [MAIN-INIT] Tab handling delegated to event-handlers.js module');
    
    // LEGACY HTMX HANDLER HINWEIS: Diese Funktionalität wird vom event-handlers.js Modul übernommen
    console.log('📡 [MAIN-INIT] HTMX event handling delegated to event-handlers.js module');
});

