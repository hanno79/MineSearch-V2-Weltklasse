// Funktion zum Testen der vollständigen Tab-Navigation
function validateTabNavigation() {
    console.log('🔧 Testing Tab Navigation Repair...');
    
    const tabs = ['csv', 'single', 'sources', 'results', 'statistics'];
    const results = [];
    
    tabs.forEach(tab => {
        const radioButton = document.getElementById(`method_${tab}`);
        const formContainer = document.getElementById(`${tab}_form`);
        
        const result = {
            tab: tab,
            radioExists: !!radioButton,
            formExists: !!formContainer,
            functional: false
        };
        
        if (radioButton && formContainer) {
            // Test tab switching
            radioButton.checked = true;
            radioButton.dispatchEvent(new Event('change'));
            result.functional = formContainer.classList.contains('active');
        }
        
        results.push(result);
        console.log(`📋 Tab '${tab}': Radio=${result.radioExists}, Form=${result.formExists}, Functional=${result.functional}`);
    });
    
    // Test Sources-specific functionality
    if (typeof loadSources === 'function') {
        console.log('✅ loadSources function available');
    } else {
        console.log('❌ loadSources function missing');
    }
    
    const sourcesContainer = document.getElementById('sources-table-container');
    console.log(`📦 Sources container: ${sourcesContainer ? 'Found' : 'Missing'}`);
    
    return results;
}

// Test Tab Navigation beim Laden
window.testTabNavigation = validateTabNavigation;

