                <div class="sources-container">
                    <div id="sources-list-${domain}" class="sources-list active">
                        ${generateEnhancedSourcesList(sources)}
                    </div>
                    
                    <div id="sources-grid-${domain}" class="sources-grid" style="display: none; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 20px;">
                        ${generateEnhancedSourcesGrid(sources)}
