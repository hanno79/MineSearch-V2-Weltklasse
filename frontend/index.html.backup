            </div>
            <div style="background: #fff3e0; padding: 20px; border-radius: 8px; text-align: center;">
                <h3 style="margin: 0 0 10px 0; color: #ff9800;">📊 Gefundene Felder</h3>
                <div style="font-size: 24px; font-weight: bold; color: #f57c00;">${(stats.avg_fields_found || 0).toFixed(1)}</div>
                <div style="font-size: 12px; color: #666; margin-top: 5px;">Durchschnitt</div>
            </div>
            <div style="background: #f3e5f5; padding: 20px; border-radius: 8px; text-align: center;">
                <h3 style="margin: 0 0 10px 0; color: #9c27b0;">⚡ Response Zeit</h3>
                <div style="font-size: 24px; font-weight: bold; color: #7b1fa2;">${(stats.avg_response_time_ms || 0).toFixed(0)}ms</div>
                <div style="font-size: 12px; color: #666; margin-top: 5px;">Durchschnitt</div>
            </div>
