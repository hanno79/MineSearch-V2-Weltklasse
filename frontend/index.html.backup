        else if (model.score_category === 'Sehr Gut') rowStyle += ' border-left: 4px solid #0891b2;';
        else if (model.score_category === 'Ungeeignet') rowStyle += ' border-left: 4px solid #dc2626;';
        
        tableHtml += `
            <tr style="${rowStyle} border-bottom: 1px solid #e5e7eb; transition: all 0.2s ease;" 
                onmouseover="this.style.backgroundColor='#f3f4f6';" 
                onmouseout="this.style.backgroundColor='${index % 2 === 1 ? '#f9fafb' : 'white'}';">
                <td style="padding: 16px 12px; border-right: 1px solid #e5e7eb;">
                    <div style="font-weight: bold; color: #1f2937; font-size: 14px; margin-bottom: 4px;">
                        ${sanitizeHTML(model.model_name)}
                    </div>
                    <div style="color: #6b7280; font-size: 12px;">
                        Provider: ${sanitizeHTML(model.provider)} | ${model.score_category}
                    </div>
                </td>
                <td style="padding: 16px 12px; text-align: center; border-right: 1px solid #e5e7eb;">
                    <div style="font-size: 20px; font-weight: bold; color: ${scoreColor};">
                        ${model.overall_score}%
                    </div>
                    <div style="font-size: 11px; color: #6b7280; margin-top: 2px;">
                        ${model.score_category}
                    </div>
                </td>
                <td style="padding: 16px 12px; text-align: center; border-right: 1px solid #e5e7eb;">
                    <div style="font-weight: bold; color: #374151;">
                        ${model.completeness_score}%
                    </div>
                    <div style="font-size: 11px; color: #6b7280;">
                        ${model.avg_fields_found} / ${model.total_expected_fields || 20} Felder
                    </div>
                </td>
                <td style="padding: 16px 12px; text-align: center; border-right: 1px solid #e5e7eb;">
                    <div style="font-weight: bold; color: ${consistencyColor};">
                        ${model.consistency_score}%
                    </div>
                    <div style="font-size: 11px; color: #6b7280;">
                        Note: ${model.consistency_grade}
                    </div>
                </td>
                <td style="padding: 16px 12px; text-align: center; border-right: 1px solid #e5e7eb;">
                    <div style="font-weight: bold; color: #374151;">
                        ${model.source_diversity_score}%
                    </div>
                    <div style="font-size: 11px; color: #6b7280;">
                        ${model.unique_sources_total} Quellen
                    </div>
                </td>
                <td style="padding: 16px 12px; text-align: center; border-right: 1px solid #e5e7eb;">
                    <div style="color: #374151; font-weight: bold;">
                        ${model.performance_category}
                    </div>
                    <div style="font-size: 11px; color: #6b7280;">
                        ${Math.round(model.avg_search_duration_ms / 1000)}s Ø
                    </div>
                </td>
                <td style="padding: 16px 12px; text-align: center; border-right: 1px solid #e5e7eb;">
                    <div style="font-weight: bold; color: #374151;">
                        ${model.total_searches}
                    </div>
                    <div style="font-size: 11px; color: #6b7280;">
                        ${model.success_rate_percent}% Erfolg
                    </div>
                </td>
                <td style="padding: 16px 12px; text-align: center;">
                    <div style="display: flex; flex-direction: column; gap: 6px;">
                        <button class="model-detail-btn" data-model-id="${model.model_id.replace(/"/g, '&quot;')}"
                                onclick="showModelDetails('${model.model_id.replace(/'/g, '\\\'')}')"
                                style="background: linear-gradient(135deg, #3b82f6 0%, #1d4ed8 100%); color: white; border: none; padding: 8px 12px; border-radius: 6px; cursor: pointer; font-size: 12px; font-weight: 600; transition: all 0.2s ease;"
                                onmouseover="this.style.transform='scale(1.05)'"
                                onmouseout="this.style.transform='scale(1)'">
                                📊 Details
                        </button>
                        <button class="model-consistency-btn" data-model-id="${model.model_id.replace(/"/g, '&quot;')}"
                                style="background: linear-gradient(135deg, #7c3aed 0%, #5b21b6 100%); color: white; border: none; padding: 8px 12px; border-radius: 6px; cursor: pointer; font-size: 12px; font-weight: 600; transition: all 0.2s ease;"
                                onmouseover="this.style.transform='scale(1.05)'"
                                onmouseout="this.style.transform='scale(1)'">
                                🎯 Konsistenz
                        </button>
                    </div>
                </td>
            </tr>
        `;
    });
    
    tableHtml += `</tbody></table></div>`;
    
    // Score-Verteilung Legende
    if (summary && summary.score_distribution) {
        const dist = summary.score_distribution;
        tableHtml += `
            <div style="margin-top: 20px; padding: 20px; background: #f8fafc; border-radius: 8px; border: 1px solid #e5e7eb;">
                <h4 style="margin: 0 0 15px 0; color: #374151;">📊 Score-Verteilung:</h4>
                <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(120px, 1fr)); gap: 15px;">
                    <div style="text-align: center;"><strong style="color: #059669;">${dist.exzellent || 0}</strong><br><span style="font-size: 12px;">Exzellent</span></div>
                    <div style="text-align: center;"><strong style="color: #0891b2;">${dist.sehr_gut || 0}</strong><br><span style="font-size: 12px;">Sehr Gut</span></div>
                    <div style="text-align: center;"><strong style="color: #ea580c;">${dist.gut || 0}</strong><br><span style="font-size: 12px;">Gut</span></div>
                    <div style="text-align: center;"><strong style="color: #d97706;">${dist.limitiert || 0}</strong><br><span style="font-size: 12px;">Limitiert</span></div>
                    <div style="text-align: center;"><strong style="color: #dc2626;">${dist.ungeeignet || 0}</strong><br><span style="font-size: 12px;">Ungeeignet</span></div>
                </div>
            </div>
        `;
    }
    
    container.innerHTML = tableHtml;
    console.log('✅ [COMPREHENSIVE-DISPLAY] Comprehensive model statistics table rendered successfully');
}

/**
 * NEUE COMPREHENSIVE FUNCTION: Details-Modal für umfassende Modell-Analyse
 * Ruft neue comprehensive API auf und zeigt erweiterte Metriken
 */
// Event-Listener für Model-Detail-Buttons (sichere Alternative zu onclick)
document.addEventListener('click', function(e) {
    if (e.target.classList.contains('model-detail-btn')) {
        const modelId = e.target.getAttribute('data-model-id');
        if (modelId) {
            showComprehensiveModelDetails(modelId);
        }
    }
    
    if (e.target.classList.contains('model-consistency-btn')) {
        const modelId = e.target.getAttribute('data-model-id');
        if (modelId && typeof showFieldConsistency === 'function') {
            showFieldConsistency(modelId);
        }
    }
});

window.showComprehensiveModelDetails = async function(modelId) {
    console.log(`🏆 [COMPREHENSIVE-DETAILS] Loading comprehensive analysis for model: ${modelId}`);
    showNotification(`🔍 Lade umfassende Analyse für ${modelId}...`, 'info');
    
    try {
        // Rufe comprehensive model details API auf
        const response = await fetch(`${window.API_BASE_URL}/api/statistics/models/comprehensive?model_filter=${encodeURIComponent(modelId)}&_cache_bust=${Date.now()}`);
        
        if (!response.ok) {
            throw new Error(`HTTP ${response.status}: ${response.statusText}`);
        }
        
        const data = await response.json();
        
        if (data.success && data.data && data.data.models && data.data.models.length > 0) {
            const modelData = data.data.models.find(m => m.model_id === modelId) || data.data.models[0];
            displayComprehensiveDetailsModal(modelId, modelData);
            showNotification(`✅ Umfassende Analyse für ${modelId} geladen`, 'success');
        } else {
            throw new Error('Comprehensive Modell-Details nicht verfügbar');
        }
        
    } catch (error) {
        console.error(`❌ [COMPREHENSIVE-DETAILS] Error loading comprehensive details for ${modelId}:`, error);
        showNotification(`❌ Fehler beim Laden der umfassenden Analyse für ${modelId}`, 'error');
    }
};

/**
 * NEUE FIELD CONSISTENCY FUNCTION: Feld-spezifische Konsistenz-Analyse
 * Ruft field consistency API auf und zeigt detaillierte Feld-Performance
 */
window.showFieldConsistency = async function(modelId) {
    console.log(`🎯 [FIELD-CONSISTENCY] Loading field consistency analysis for model: ${modelId}`);
    showNotification(`🔍 Lade Feld-Konsistenz-Analyse für ${modelId}...`, 'info');
    
    try {
        // Rufe field consistency API auf
        const response = await fetch(`${window.API_BASE_URL}/api/statistics/models/${encodeURIComponent(modelId)}/field-consistency?_cache_bust=${Date.now()}`);
        
        if (!response.ok) {
            throw new Error(`HTTP ${response.status}: ${response.statusText}`);
        }
        
        const data = await response.json();
        
        if (data.success && data.data) {
            displayFieldConsistencyModal(modelId, data.data);
            showNotification(`✅ Feld-Konsistenz-Analyse für ${modelId} geladen`, 'success');
        } else {
            throw new Error('Feld-Konsistenz-Daten nicht verfügbar');
        }
        
    } catch (error) {
        console.error(`❌ [FIELD-CONSISTENCY] Error loading field consistency for ${modelId}:`, error);
        showNotification(`❌ Fehler beim Laden der Feld-Konsistenz-Analyse für ${modelId}`, 'error');
    }
};

/**
 * NEUE COMPREHENSIVE DETAILS MODAL: Erweiterte Tab-Navigation für Modell-Details
 */
function displayComprehensiveDetailsModal(modelId, modelData) {
    console.log(`🎯 [COMPREHENSIVE-MODAL] Displaying comprehensive details for ${modelId}`);
    
    const modal = document.createElement('div');
    modal.className = 'comprehensive-details-modal';
    modal.style.cssText = `
        position: fixed; top: 0; left: 0; width: 100%; height: 100%; 
        background: rgba(0,0,0,0.8); z-index: 10000; display: flex; 
        align-items: center; justify-content: center; padding: 20px;
    `;
    
    const modalContent = document.createElement('div');
    modalContent.style.cssText = `
        background: white; border-radius: 12px; box-shadow: 0 25px 50px rgba(0,0,0,0.3);
        width: 95%; max-width: 1200px; max-height: 90%; display: flex; flex-direction: column;
        overflow: hidden;
    `;
    
    // Header mit Close-Button und Modell-Info
    const header = document.createElement('div');
    header.style.cssText = `
        background: linear-gradient(135deg, #2563eb 0%, #7c3aed 100%); color: white; 
        padding: 20px; display: flex; justify-content: space-between; align-items: center;
    `;
    
    header.innerHTML = `
        <div>
            <h2 style="margin: 0 0 5px 0; font-size: 24px;">🏆 ${sanitizeHTML(modelData.model_name)}</h2>
            <p style="margin: 0; opacity: 0.9; font-size: 14px;">
                ${sanitizeHTML(modelData.provider)} | ${modelData.score_category} | ${modelData.overall_score}% Gesamtscore
            </p>
        </div>
        <button onclick="this.closest('.comprehensive-details-modal').remove()" 
                style="background: rgba(255,255,255,0.2); border: none; color: white; border-radius: 50%; 
                       width: 40px; height: 40px; cursor: pointer; font-size: 20px; display: flex; 
                       align-items: center; justify-content: center;">✕</button>
    `;
    
    // Tab Navigation
    const tabsContainer = document.createElement('div');
    tabsContainer.style.cssText = `
        background: #f8fafc; border-bottom: 1px solid #e5e7eb; display: flex;
    `;
    
    const tabs = [
        { id: 'overview', label: '📊 Überblick', active: true },
        { id: 'scores', label: '🏆 Scores', active: false },
        { id: 'fields', label: '📋 Felder', active: false },
        { id: 'performance', label: '⚡ Performance', active: false }
    ];
    
    tabs.forEach(tab => {
        const tabButton = document.createElement('button');
        tabButton.style.cssText = `
            background: ${tab.active ? 'white' : 'transparent'}; 
            border: none; border-bottom: 3px solid ${tab.active ? '#2563eb' : 'transparent'};
            padding: 15px 20px; cursor: pointer; font-weight: 600; color: ${tab.active ? '#2563eb' : '#6b7280'};
            transition: all 0.2s ease;
        `;
        tabButton.textContent = tab.label;
        tabButton.onclick = () => switchComprehensiveTab(tab.id, modelData);
        tabsContainer.appendChild(tabButton);
    });
    
    // Content Area
    const contentArea = document.createElement('div');
    contentArea.id = 'comprehensive-modal-content';
    contentArea.style.cssText = `
        flex: 1; overflow-y: auto; padding: 0;
    `;
    
    modal.appendChild(modalContent);
    modalContent.appendChild(header);
    modalContent.appendChild(tabsContainer);
    modalContent.appendChild(contentArea);
    
    document.body.appendChild(modal);
    
    // Load initial tab content
    switchComprehensiveTab('overview', modelData);
    
    // Close on background click
    modal.onclick = (e) => {
        if (e.target === modal) modal.remove();
    };
}

/**
 * NEUE FIELD CONSISTENCY MODAL: Detaillierte Feld-Performance-Analyse
 */
function displayFieldConsistencyModal(modelId, consistencyData) {
    console.log(`🎯 [FIELD-CONSISTENCY-MODAL] Displaying field consistency for ${modelId}`);
    
    const modal = document.createElement('div');
    modal.className = 'field-consistency-modal';
    modal.style.cssText = `
        position: fixed; top: 0; left: 0; width: 100%; height: 100%; 
        background: rgba(0,0,0,0.8); z-index: 10000; display: flex; 
        align-items: center; justify-content: center; padding: 20px;
    `;
    
    const modalContent = document.createElement('div');
    modalContent.style.cssText = `
        background: white; border-radius: 12px; box-shadow: 0 25px 50px rgba(0,0,0,0.3);
        width: 95%; max-width: 1000px; max-height: 90%; display: flex; flex-direction: column;
        overflow: hidden;
    `;
    
    // Header
    const header = document.createElement('div');
    header.style.cssText = `
        background: linear-gradient(135deg, #7c3aed 0%, #5b21b6 100%); color: white; 
        padding: 20px; display: flex; justify-content: space-between; align-items: center;
    `;
    
    header.innerHTML = `
        <div>
            <h2 style="margin: 0 0 5px 0; font-size: 22px;">🎯 Feld-Konsistenz-Analyse</h2>
            <p style="margin: 0; opacity: 0.9; font-size: 14px;">
                Modell: ${sanitizeHTML(modelId)} | ${consistencyData.field_analyses ? Object.keys(consistencyData.field_analyses).length : 0} Felder analysiert
            </p>
        </div>
        <button onclick="this.closest('.field-consistency-modal').remove()" 
                style="background: rgba(255,255,255,0.2); border: none; color: white; border-radius: 50%; 
                       width: 40px; height: 40px; cursor: pointer; font-size: 20px; display: flex; 
                       align-items: center; justify-content: center;">✕</button>
    `;
    
    // Content
    const content = document.createElement('div');
    content.style.cssText = `
        flex: 1; overflow-y: auto; padding: 25px;
    `;
    
    // Summary
    const summary = consistencyData.summary || {};
    content.innerHTML = `
        <div style="background: #f8fafc; padding: 20px; border-radius: 8px; margin-bottom: 25px; border: 1px solid #e5e7eb;">
            <h3 style="margin: 0 0 15px 0; color: #374151;">📊 Konsistenz-Übersicht</h3>
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 15px;">
                <div style="text-align: center;">
                    <div style="font-size: 24px; font-weight: bold; color: #7c3aed;">${summary.avg_consistency || 0}%</div>
                    <div style="font-size: 14px; color: #6b7280;">Ø Konsistenz</div>
                </div>
                <div style="text-align: center;">
                    <div style="font-size: 24px; font-weight: bold; color: #059669;">${summary.most_consistent_fields?.length || 0}</div>
                    <div style="font-size: 14px; color: #6b7280;">Konsistente Felder</div>
                </div>
                <div style="text-align: center;">
                    <div style="font-size: 24px; font-weight: bold; color: #dc2626;">${summary.least_consistent_fields?.length || 0}</div>
                    <div style="font-size: 14px; color: #6b7280;">Inkonsistente Felder</div>
                </div>
            </div>
        </div>
        
        <h3 style="margin: 0 0 20px 0; color: #374151;">📋 Feld-spezifische Analyse</h3>
        <div id="field-consistency-table"></div>
    `;
    
    // Field consistency table
    if (consistencyData.field_analyses) {
        const fieldTable = content.querySelector('#field-consistency-table');
        let tableHtml = `
            <div style="overflow-x: auto;">
                <table style="width: 100%; border-collapse: collapse; border: 1px solid #e5e7eb; border-radius: 8px; overflow: hidden;">
                    <thead style="background: #f9fafb;">
                        <tr>
                            <th style="padding: 12px; text-align: left; border-bottom: 1px solid #e5e7eb; font-weight: 600;">Feld</th>
                            <th style="padding: 12px; text-align: center; border-bottom: 1px solid #e5e7eb; font-weight: 600;">Konsistenz</th>
                            <th style="padding: 12px; text-align: center; border-bottom: 1px solid #e5e7eb; font-weight: 600;">Gefunden</th>
                            <th style="padding: 12px; text-align: center; border-bottom: 1px solid #e5e7eb; font-weight: 600;">Variationen</th>
                            <th style="padding: 12px; text-align: center; border-bottom: 1px solid #e5e7eb; font-weight: 600;">Bewertung</th>
                        </tr>
                    </thead>
                    <tbody>
        `;
        
        Object.entries(consistencyData.field_analyses).forEach(([fieldName, analysis], index) => {
            const consistencyColor = analysis.consistency_percent >= 80 ? '#059669' : 
                                   analysis.consistency_percent >= 60 ? '#0891b2' : 
                                   analysis.consistency_percent >= 40 ? '#ea580c' : '#dc2626';
            
            tableHtml += `
                <tr style="background: ${index % 2 === 1 ? '#f9fafb' : 'white'};">
                    <td style="padding: 12px; border-bottom: 1px solid #e5e7eb; font-weight: 500;">
                        ${sanitizeHTML(fieldName)}
                    </td>
                    <td style="padding: 12px; text-align: center; border-bottom: 1px solid #e5e7eb;">
                        <span style="font-weight: bold; color: ${consistencyColor};">${analysis.consistency_percent || 0}%</span>
                    </td>
                    <td style="padding: 12px; text-align: center; border-bottom: 1px solid #e5e7eb;">
                        ${analysis.found_count || 0} / ${analysis.total_searches || 0}
                    </td>
                    <td style="padding: 12px; text-align: center; border-bottom: 1px solid #e5e7eb;">
                        ${analysis.value_variations?.length || 0}
                    </td>
                    <td style="padding: 12px; text-align: center; border-bottom: 1px solid #e5e7eb;">
                        <span style="background: ${consistencyColor}; color: white; padding: 4px 8px; border-radius: 12px; font-size: 12px; font-weight: bold;">
                            ${analysis.consistency_grade || 'N/A'}
                        </span>
                    </td>
                </tr>
            `;
        });
        
        tableHtml += '</tbody></table></div>';
        fieldTable.innerHTML = tableHtml;
    }
    
    modal.appendChild(modalContent);
    modalContent.appendChild(header);
    modalContent.appendChild(content);
    
    document.body.appendChild(modal);
    
    // Close on background click
    modal.onclick = (e) => {
        if (e.target === modal) modal.remove();
    };
}

