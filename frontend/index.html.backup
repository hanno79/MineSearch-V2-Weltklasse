/**
 * NEUE UMFASSENDE FUNKTION: Zeigt erweiterte Modell-Statistiken mit Gesamtscore
 * Nutzt die neue comprehensive API mit normiertem Score-System
 */
function displayComprehensiveModelStatistics(models, summary) {
    console.log('🎯 [COMPREHENSIVE-DISPLAY] Rendering comprehensive model statistics table');
    
    const container = document.getElementById('model-statistics-table-container') || document.getElementById('enhanced-statistics-table-container');
    if (!container) return;
    
    // Summary-Box mit umfassender Übersicht
    const summaryHtml = `
        <div style="background: linear-gradient(135deg, #2563eb 0%, #7c3aed 100%); color: white; padding: 25px; border-radius: 12px; margin-bottom: 25px; box-shadow: 0 8px 25px rgba(0,0,0,0.15);">
            <h3 style="margin: 0 0 20px 0; font-size: 22px; text-align: center;">🏆 Umfassende Modell-Performance Analyse</h3>
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 20px;">
                <div style="text-align: center; background: rgba(255,255,255,0.1); padding: 15px; border-radius: 8px;">
                    <div style="font-size: 28px; font-weight: bold; margin-bottom: 5px;">${summary?.total_models || models.length}</div>
