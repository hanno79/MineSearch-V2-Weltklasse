# API Keys für MineSearch
# Kopiere diese Datei nach .env und trage deine Keys ein

# OpenRouter (für Claude & GPT-4)
OPENROUTER_API_KEY=

# Perplexity AI
PERPLEXITY_API_KEY=

# Tavily Search
TAVILY_API_KEY=

# Exa AI
EXA_API_KEY=

# Apify
APIFY_API_KEY=

# ScrapingBee
SCRAPINGBEE_API_KEY=

# Firecrawl
FIRECRAWL_API_KEY=

# Bright Data
BRIGHTDATA_API_KEY=

# Optional: Database path
DATABASE_PATH=data/minesearch.db

# Optional: Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO