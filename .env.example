# MineSearch v2 - Umgebungsvariablen Konfiguration
# Kopiere diese Datei zu .env und setze die entsprechenden Werte

# GitHub Integration
GITHUB_TOKEN=your_github_token_here

# API-Keys für Provider
PERPLEXITY_API_KEY=your_perplexity_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here  
TAVILY_API_KEY=your_tavily_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
GROK_API_KEY=your_grok_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Scraping Provider
EXA_API_KEY=your_exa_api_key_here
APIFY_API_KEY=your_apify_api_key_here
SCRAPINGBEE_API_KEY=your_scrapingbee_api_key_here
FIRECRAWL_API_KEY=your_firecrawl_api_key_here
BRIGHTDATA_API_KEY=your_brightdata_api_key_here

# Datenbank
DATABASE_URL=sqlite:///minesearch_v2/backend/mines.db
DATABASE_PATH=data/minesearch.db

# Server-Konfiguration
HOST=0.0.0.0
PORT=8000
DEBUG=false

# API-Konfiguration
API_BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
API_TIMEOUT=30
MAX_RETRIES=3

# Modell-Konfiguration
DEFAULT_MODEL=openrouter:kimi-k2
PERPLEXITY_TEMPERATURE=0.2

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/minesearch.log

# Cache-Konfiguration
CACHE_TTL=3600
CACHE_MAX_SIZE=1000

# Rate-Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Security
JWT_SECRET_KEY=your_jwt_secret_key_here
CORS_ORIGINS=http://localhost:3000,http://localhost:8000